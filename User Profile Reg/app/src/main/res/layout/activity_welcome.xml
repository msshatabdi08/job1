<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F5F9"
    android:padding="24dp">

    <!-- Center Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/centerCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="28dp"
        app:cardElevation="10dp"
        app:strokeColor="#E2E8F0"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="28dp">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WELCOME TO"
                android:textSize="13sp"
                android:textColor="#64748B"
                android:textStyle="bold"
                android:letterSpacing="0.2"/>

            <TextView
                android:id="@+id/tvAppName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User Profile App"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#0F172A"
                android:layout_marginTop="6dp"/>

            <!-- Accent Line -->
            <View
                android:layout_width="80dp"
                android:layout_height="4dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="14dp"
                android:background="#2563EB"/>

            <!-- Description -->
            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage your profiles efficiently, securely and beautifully"
                android:textSize="15sp"
                android:textColor="#64748B"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

            <!-- Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnProfileList"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="View Profile List"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                app:backgroundTint="#2563EB"
                app:cornerRadius="16dp"
                app:elevation="6dp"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>